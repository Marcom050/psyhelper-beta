# PsyHelper local development defaults (no real secrets)
ENVIRONMENT=development
SECRET_KEY=dev-secret-change-me-at-least-32-characters
DEBUG=true
TESTING=false

# Persistence backend
USE_POSTGRESQL=false
DATABASE_URL=postgresql://psyhelper:psyhelper@localhost:5432/psyhelper
USE_FILESYSTEM_FALLBACK=true

# Persistence paths (required for production)
AUTH_SECURITY_STATE_PATH=./data/auth_security_state.json
AUDIT_LOG_PATH=./data/audit.log
DATA_RIGHTS_STORAGE_PATH=./data/data_rights_requests.json
EXPORT_OUTPUT_PATH=./tmp/exports

# Governance/security flags
STRICT_PRODUCTION_MODE=false
ADMIN_BOOTSTRAP_MODE=cli
ADMIN_BOOTSTRAP_SECRET=replace-with-32-char-bootstrap-secret
PRIVACY_POLICY_VERSION=2026-01
TERMS_VERSION=2026-01
CONSENT_ENFORCEMENT_ENABLED=true
DATA_EXPORT_ENABLED=true

# API/runtime
CORS_ALLOWED_ORIGINS=http://localhost:8501,http://localhost:8000
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
TOKEN_ISSUER=psyhelper-beta
DB_CONNECT_TIMEOUT_SEC=5
DB_STATEMENT_TIMEOUT_MS=5000
LOGIN_RATE_LIMIT_ATTEMPTS=8
LOGIN_RATE_LIMIT_WINDOW_SEC=60
LOGIN_LOCKOUT_SEC=300
BETA_TRIAL_DAYS=14

# Streamlit/UI
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
API_BASE_URL=http://localhost:8000
