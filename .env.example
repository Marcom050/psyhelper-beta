ENVIRONMENT=development
STRICT_PRODUCTION_MODE=false
SECRET_KEY=change-me-with-at-least-32-characters
USE_POSTGRESQL=true
DATABASE_URL=postgresql://postgres:postgres@db:5432/psyhelper
USE_FILESYSTEM_FALLBACK=false
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
TOKEN_ISSUER=psyhelper-beta
DB_CONNECT_TIMEOUT_SEC=5
DB_STATEMENT_TIMEOUT_MS=5000
LOGIN_RATE_LIMIT_ATTEMPTS=8
LOGIN_RATE_LIMIT_WINDOW_SEC=60
LOGIN_LOCKOUT_SEC=300
