# PsyHelper production template for controlled private beta (no real secrets)
ENVIRONMENT=production
SECRET_KEY=replace-with-very-long-random-secret-min-32
DEBUG=false
TESTING=false
STRICT_PRODUCTION_MODE=true

# Production persistence: PostgreSQL only
USE_POSTGRESQL=true
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
USE_FILESYSTEM_FALLBACK=false

# Persistent state paths (must be mounted persistent volumes if used)
AUTH_SECURITY_STATE_PATH=/persistent/psyhelper/auth_security_state.json
AUDIT_LOG_PATH=/persistent/psyhelper/audit.log
DATA_RIGHTS_STORAGE_PATH=/persistent/psyhelper/data_rights_requests.json
EXPORT_OUTPUT_PATH=/tmp/psyhelper-exports

# Governance/security
ADMIN_BOOTSTRAP_MODE=disabled
ADMIN_BOOTSTRAP_SECRET=replace-with-very-long-random-bootstrap-secret-min-32
PRIVACY_POLICY_VERSION=2026-01
TERMS_VERSION=2026-01
CONSENT_ENFORCEMENT_ENABLED=true
DATA_EXPORT_ENABLED=true
CORS_ALLOWED_ORIGINS=https://your-streamlit-app.streamlit.app

# Runtime
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
TOKEN_ISSUER=psyhelper-private-beta
DB_CONNECT_TIMEOUT_SEC=5
DB_STATEMENT_TIMEOUT_MS=5000
LOGIN_RATE_LIMIT_ATTEMPTS=8
LOGIN_RATE_LIMIT_WINDOW_SEC=60
LOGIN_LOCKOUT_SEC=300
BETA_TRIAL_DAYS=14

# Streamlit/API settings
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
API_BASE_URL=https://your-api-host.example.com
